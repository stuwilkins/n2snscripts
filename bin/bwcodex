#!/usr/bin/env bash
# bwcodex — Launch OpenAI Codex CLI inside a bubblewrap (bwrap) sandbox.
#
# Requires: bwrap >= 0.4.0 (RHEL 8)
#   - 0.4.0: base functionality
#   - 0.5.0+: --clearenv (fallback: manual --unsetenv for each host var)
#   - 0.6.3+: bind over ro-bind (fallback: skip binary masking)
#
# Two approved auth paths are supported (configured in ~/.codex/config.toml):
#   - Hermes (AIFAPIM) routing — provider block points at
#       https://${AIFAPIM_HOST}/openai/v1 with x-api-key header;
#       wrapper plumbs AIFAPIM_HOST + AIFAPIM_API_KEY through.  Set
#       OPENAI_API_KEY=dummy on the host or rely on the wrapper default.
#   - BNL ITD ChatGPT subscription — `codex login` OAuth flow persists
#       tokens to ~/.codex/auth.json.  Run once with --init-auth to make
#       that file persist across sandbox invocations.
#
# Note: Codex CLI also enforces its own inner Landlock-based sandbox for
# agent tool calls.  The outer bwrap here is complementary — it scopes
# the entire Codex process tree, not just agent-issued commands.
#
# The sandbox provides filesystem isolation:
#   - Current directory: read-write
#   - Codex home (~/.codex or $CODEX_HOME): tmpfs (ephemeral by default)
#     - sessions/: bind-mounted read-write (for `codex resume` / `codex fork`)
#     - log/: bind-mounted read-write (RUST_LOG / opt-in plaintext logs)
#     - history.jsonl: bind-mounted read-write (prompt history)
#     - config.toml: by default, copied to a per-session staging file and
#         bind-mounted RW so Codex can persist project-trust grants for the
#         session without touching the host file (the staging copy is removed
#         on script exit).  With --persist-config, the host config.toml is
#         bind-mounted RW so writes persist across sessions at the cost of
#         weaker isolation.  Either the user file or the system file
#         (/etc/codex/config.toml) is sufficient for fail-fast.
#   - /etc/codex/config.toml: system-wide provider/defaults config (if
#       present); bind-mounted read-only.  Codex layers user config on
#       top of this file.
#   - /etc/codex/requirements.toml: admin-enforced restrictions (if
#       present); bind-mounted read-only.  Users cannot loosen these.
#     - AGENTS.md: bind-mounted read-only (if it exists)
#     - skills/: bind-mounted read-only (if it exists)
#     - packages/: bind-mounted read-only (if it exists, installer cache)
#     - auth.json: bind-mounted read-write only if it already exists on host;
#         --init-auth creates a {} stub for first-time ChatGPT-login setup
#     - Everything else (tmp/, state.toml, features/, ...): tmpfs, discarded on exit
#   - Codex CLI binary + npm prefix: read-only (handled by build_dynamic_tool_mounts)
#   - Git config + includes: read-only
#   - Pixi cache: read-write
#   - Pixi config: read-only
#   - ccache config: read-only
#   - ccache cache: read-write
#   - npm config: read-only
#   - npm cache: read-write
#   - System and user binaries: read-only
#   - SSH binaries: masked (ssh, scp, sftp, ssh-agent, etc.)
#   - Network tools: masked (telnet, nc/ncat, socat, rsync, rsh)
#   - Kerberos tools: masked (kinit, klist, kdestroy, kswitch)
#   - Privilege escalation: masked (sudo, su, pkexec)
#   - Namespace tools: masked (nsenter, unshare, chroot)
#   - Keyring tools: masked (keyctl)
#   - SSH/GPG agent env vars: stripped
#   - ~/.bashrc and other shell rc files: not mounted
#
# Usage:
#   bwcodex [bwcodex-options] [codex arguments...]
#   bwcodex --help
#
# Options:
#   --help, -h      Show this help (wrapper options + codex's own help).
#   --dry-run       Print the bwrap command that would be executed without running it.
#   --exec CMD      Run CMD inside the sandbox instead of codex.
#                   Useful for running one-off commands, scripts, or diagnostic tools
#                   inside the fully-configured sandbox environment.
#   --init-auth     Create ~/.codex/auth.json on the host so that ChatGPT-login
#                   OAuth tokens persist across sessions.  Only meaningful for the
#                   BNL ITD ChatGPT subscription auth path; has no effect for
#                   Hermes-routed setups.  On shared accounts, do NOT use this
#                   flag — tokens will be ephemeral by default.
#   --persist-config Bind ~/.codex/config.toml read-write into the sandbox so
#                   writes persist across sessions.  Default: config.toml is
#                   copied to a per-session staging file; host file is unchanged.
#   --debug         Enable verbose Codex logging (sets RUST_LOG=debug).
#   --new-session   Force bwrap --new-session even on kernels with the TIOCSTI cap
#                   guard.  Detaches the controlling tty for stricter isolation at the
#                   cost of SIGWINCH (terminal resize) propagation.
#   --ro-path PATH  Mount PATH read-only into the sandbox.  May be repeated to
#                   accumulate multiple paths.  Dangerous paths are blocked:
#                   $HOME and ancestors, ~/.ssh, ~/.gnupg, ~/.aws, ~/.kube,
#                   ~/.docker, ~/.netrc, ~/.pypirc, ~/.rattler, ~/.yarnrc,
#                   ~/.yarnrc.yml, ~/.yarn, ~/.config/gh,
#                   $XDG_DATA_HOME/uv/credentials, /root, /etc/shadow,
#                   /etc/sudoers{,.d}.
#   --rw-path PATH  Mount PATH read-write into the sandbox.  May be repeated to
#                   accumulate multiple paths.  Same blocked-path rules as --ro-path.

set -euo pipefail

# Source the shared sandbox library.
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
# shellcheck source=../lib/bwrap_sandbox_lib.sh
source "${SCRIPT_DIR}/../lib/bwrap_sandbox_lib.sh"

# ═══════════════════════════════════════════════════════════════════
# Tool-specific state
# ═══════════════════════════════════════════════════════════════════

INIT_AUTH=0
DEBUG_MODE=0
PERSIST_CONFIG=0

# ═══════════════════════════════════════════════════════════════════
# Tool-specific functions
# ═══════════════════════════════════════════════════════════════════

parse_wrapper_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help | -h)
                SHOW_HELP=1
                shift
                ;;
            --dry-run)
                DRY_RUN=1
                shift
                ;;
            --exec)
                if [[ $# -lt 2 ]]; then
                    echo "Error: --exec requires a command argument." >&2
                    exit 1
                fi
                TEST_CMD="$2"
                shift 2
                ;;
            --init-auth)
                INIT_AUTH=1
                shift
                ;;
            --persist-config)
                PERSIST_CONFIG=1
                shift
                ;;
            --debug)
                DEBUG_MODE=1
                shift
                ;;
            --new-session)
                # shellcheck disable=SC2034  # consumed by sourced bwrap_sandbox_lib.sh (sandboxed_exec)
                FORCE_NEW_SESSION=1
                shift
                ;;
            --ro-path)
                if [[ $# -lt 2 ]]; then
                    echo "Error: --ro-path requires a path argument." >&2
                    exit 1
                fi
                EXTRA_RO_PATHS+=("$2")
                shift 2
                ;;
            --rw-path)
                if [[ $# -lt 2 ]]; then
                    echo "Error: --rw-path requires a path argument." >&2
                    exit 1
                fi
                EXTRA_RW_PATHS+=("$2")
                shift 2
                ;;
            *)
                break
                ;;
        esac
    done
    # shellcheck disable=SC2034  # consumed by library's print_dry_run/launch_sandbox
    TOOL_ARGS=("$@")
}

# Find the absolute path to the codex binary on the host so we do
# not depend on PATH lookup inside the sandbox.
# Sets globals: _TOOL_BIN, _TOOL_CMD
resolve_tool_binary() {
    _TOOL_BIN="$(command -v codex 2> /dev/null || true)"
    if [[ -z "${_TOOL_BIN}" ]]; then
        echo "Error: 'codex' not found in PATH." >&2
        exit 1
    fi

    if [[ -n "${TEST_CMD}" ]]; then
        # Split TEST_CMD into array so multi-word commands work correctly.
        read -ra _TOOL_CMD <<< "${TEST_CMD}"
    else
        _TOOL_CMD=("${_TOOL_BIN}")
    fi
}

show_help() {
    cat << 'HELP_EOF'
bwcodex — OpenAI Codex CLI inside a bubblewrap sandbox

Wrapper options (consumed before codex sees the command line):
  -h, --help      Show this message followed by codex's own help.
  --dry-run       Print the bwrap command that would be run, then exit.
  --exec CMD      Run CMD inside the fully-configured sandbox instead of codex.
                  Use this to run scripts, diagnostic tools, or any command with
                  the same filesystem isolation and environment as codex itself.
                  Example: bwcodex --exec bash
                           bwcodex --exec 'env | sort'
  --init-auth     Create ~/.codex/auth.json on the host so that ChatGPT-login
                  OAuth tokens persist across sessions.  Only meaningful for the
                  BNL ITD ChatGPT subscription auth path; has no effect for
                  Hermes-routed setups.  On shared accounts, do NOT use this
                  flag — tokens will be ephemeral by default.
  --persist-config Bind ~/.codex/config.toml read-write into the sandbox so
                  Codex can persist project trust decisions and other
                  config.toml mutations across sessions.  WARNING: this
                  weakens sandbox isolation — a compromised Codex could
                  modify provider URLs, auth headers, or other config keys.
                  Concurrent --persist-config sessions may race on writes.
                  Without this flag (the default), config.toml is copied to
                  a per-session staging file and any writes are discarded
                  on exit.
  --debug         Enable verbose Codex logging (sets RUST_LOG=debug).
  --new-session   Force bwrap to call setsid(2), detaching the sandbox from the
                  controlling terminal.  This is the default on older kernels
                  (< 5.14); on newer kernels we omit it so that SIGWINCH (terminal
                  resize) propagates from tmux/screen.  Use this flag to opt back
                  into stricter terminal isolation when SIGWINCH is not important.
  --ro-path PATH  Mount PATH (file or directory) read-only into the sandbox.
                  May be repeated to accumulate multiple extra paths.
                  Blocked: $HOME and ancestors, ~/.ssh, ~/.gnupg, ~/.aws,
                  ~/.kube, ~/.docker, ~/.netrc, ~/.pypirc, ~/.rattler,
                  ~/.yarnrc, ~/.yarnrc.yml, ~/.yarn, ~/.config/gh,
                  $XDG_DATA_HOME/uv/credentials, /root, /etc/shadow,
                  /etc/sudoers{,.d}.
                  Symlinks are resolved before the safety check is applied.
  --rw-path PATH  Mount PATH (file or directory) read-write into the sandbox.
                  Same blocked-path rules as --ro-path.  May be repeated.

All other arguments are passed through to codex unchanged.

Authentication:
  Two paths are supported:
    - Hermes (AIFAPIM):  set AIFAPIM_API_KEY (e.g. via `load_dotenv`) and
                         keep OPENAI_API_KEY=dummy.  See ~/.codex/config.toml
                         for the [model_providers.nsls2-hermes] block.
    - ChatGPT login:     run `bwcodex --init-auth` once, then `bwcodex` and
                         `codex login` to populate ~/.codex/auth.json.

HELP_EOF
    # Delegate to codex --help inside the sandbox so the user sees the full
    # codex option set in the same invocation.
    exec "$0" --exec "${_TOOL_BIN} --help"
}

resolve_codex_paths() {
    # Codex home: config, auth, sessions, logs, history, skills.
    # Override: CODEX_HOME env var.  Codex CLI does NOT use XDG dirs.
    CODEX_HOME_DIR="${CODEX_HOME:-${_HOME}/.codex}"

    CODEX_CONFIG_FILE="${CODEX_HOME_DIR}/config.toml"
    CODEX_AGENTS_FILE="${CODEX_HOME_DIR}/AGENTS.md"
    CODEX_AUTH_FILE="${CODEX_HOME_DIR}/auth.json"
    CODEX_SESSIONS_DIR="${CODEX_HOME_DIR}/sessions"
    CODEX_LOG_DIR="${CODEX_HOME_DIR}/log"
    CODEX_SKILLS_DIR="${CODEX_HOME_DIR}/skills"
    CODEX_HISTORY_FILE="${CODEX_HOME_DIR}/history.jsonl"
    CODEX_PACKAGES_DIR="${CODEX_HOME_DIR}/packages"

    # Validate the user-controllable root directory once here so that all
    # sub-path mounts derived from it are implicitly covered.
    _check_dir_safe "${CODEX_HOME_DIR}" "CODEX_HOME"
}

# Ensure writable directories and files exist on host.
ensure_host_dirs() {
    mkdir -p "${CODEX_HOME_DIR}" \
             "${CODEX_SESSIONS_DIR}" \
             "${CODEX_LOG_DIR}"
    touch "${CODEX_HISTORY_FILE}"
}

# Fail fast if no config.toml exists.  Codex requires a config.toml to
# select a provider; running bwcodex without one would produce a confusing
# error from Codex itself.  Either the system-wide file (deployed by
# ansible on managed hosts) or the user file is sufficient — Codex layers
# the user file on top of the system file.
SYSTEM_CODEX_CONFIG_FILE="/etc/codex/config.toml"
SYSTEM_CODEX_REQUIREMENTS_FILE="/etc/codex/requirements.toml"
check_codex_config() {
    if [[ ! -r "${SYSTEM_CODEX_CONFIG_FILE}" ]] && [[ ! -r "${CODEX_CONFIG_FILE}" ]]; then
        printf 'Error: Codex requires a config.toml to select a provider.\n' >&2
        printf '       Checked:\n' >&2
        printf '         %s (system-wide; deployed by ansible)\n' "${SYSTEM_CODEX_CONFIG_FILE}" >&2
        printf '         %s   (user)\n' "${CODEX_CONFIG_FILE}" >&2
        printf '       Create at least one — see\n' >&2
        printf '       https://docs.nsls2.bnl.gov/docs/how-to/codex.html\n' >&2
        exit 2
    fi
}

# ── Codex home (ephemeral tmpfs + selective persistence) ─────────
# Mount the home dir as ephemeral tmpfs, then selectively bind-mount
# the files and directories that must persist across sessions.
#
# auth.json is only bind-mounted if it already exists on the host.
# If absent, codex creates it inside the tmpfs — the token is usable
# for the session but discarded on exit.  This is the desired
# behaviour for shared accounts.  On a personal account using
# ChatGPT login, run with --init-auth once to bootstrap persistent auth.
build_codex_home_mount() {
    # Create intermediate --dir entries if CODEX_HOME_DIR is nested under $HOME.
    if [[ "${CODEX_HOME_DIR}" == "${_HOME}"/* ]]; then
        local _rel="${CODEX_HOME_DIR#"${_HOME}"/}"
        local _accum="${_HOME}"
        local _parts
        IFS='/' read -ra _parts <<< "${_rel}"
        local _i
        for ((_i = 0; _i < ${#_parts[@]} - 1; _i++)); do
            _accum="${_accum}/${_parts[$_i]}"
            BWRAP_ARGS+=(--dir "${_accum}")
        done
    fi

    BWRAP_ARGS+=(--tmpfs "${CODEX_HOME_DIR}")

    # Persistent read-write directories
    local _subdir
    for _subdir in sessions log; do
        BWRAP_ARGS+=(--bind "${CODEX_HOME_DIR}/${_subdir}" "${CODEX_HOME_DIR}/${_subdir}")
    done

    # Persistent read-write files
    BWRAP_ARGS+=(--bind "${CODEX_HISTORY_FILE}" "${CODEX_HISTORY_FILE}")

    # System-wide config (Codex layers user config on top of it).  Mounted
    # read-only — users cannot mutate the institutional defaults from
    # inside the sandbox.
    if [[ -f "${SYSTEM_CODEX_CONFIG_FILE}" ]]; then
        BWRAP_ARGS+=(--ro-bind "${SYSTEM_CODEX_CONFIG_FILE}" "${SYSTEM_CODEX_CONFIG_FILE}")
    fi

    # System-wide admin-enforced restrictions (e.g. allowed_sandbox_modes).
    # Always read-only; users cannot loosen institutional restrictions.
    if [[ -f "${SYSTEM_CODEX_REQUIREMENTS_FILE}" ]]; then
        BWRAP_ARGS+=(--ro-bind "${SYSTEM_CODEX_REQUIREMENTS_FILE}" "${SYSTEM_CODEX_REQUIREMENTS_FILE}")
    fi

    # User config.toml mount strategy (see file header):
    #   - Default: stage a writable copy in /tmp, bind RW into sandbox.
    #     Codex can persist project trust / other mutations for the session,
    #     but the host ~/.codex/config.toml is never touched.  The staging
    #     file is cleaned up on script exit via the EXIT trap.
    #   - --persist-config: bind host config.toml RW so writes persist.
    # If the user file does not exist (managed host using only system
    # config), skip the user mount entirely.
    if [[ -f "${CODEX_CONFIG_FILE}" ]]; then
        if [[ "${PERSIST_CONFIG}" -eq 1 ]]; then
            BWRAP_ARGS+=(--bind "${CODEX_CONFIG_FILE}" "${CODEX_CONFIG_FILE}")
        else
            _STAGED_CONFIG="$(mktemp --tmpdir bwcodex-config.XXXXXX.toml)"
            cp -p "${CODEX_CONFIG_FILE}" "${_STAGED_CONFIG}"
            chmod u+w "${_STAGED_CONFIG}"
            trap 'rm -f "${_STAGED_CONFIG}"' EXIT INT TERM
            BWRAP_ARGS+=(--bind "${_STAGED_CONFIG}" "${CODEX_CONFIG_FILE}")
        fi
    fi

    if [[ -e "${CODEX_AGENTS_FILE}" ]]; then
        BWRAP_ARGS+=(--ro-bind "${CODEX_AGENTS_FILE}" "${CODEX_AGENTS_FILE}")
    fi

    if [[ -d "${CODEX_SKILLS_DIR}" ]]; then
        BWRAP_ARGS+=(--ro-bind "${CODEX_SKILLS_DIR}" "${CODEX_SKILLS_DIR}")
    fi

    if [[ -d "${CODEX_PACKAGES_DIR}" ]]; then
        BWRAP_ARGS+=(--ro-bind "${CODEX_PACKAGES_DIR}" "${CODEX_PACKAGES_DIR}")
    fi

    # auth.json: only persist if it already exists on the host.
    # Use --init-auth on first run to bootstrap persistent ChatGPT-login auth.
    if [[ "${INIT_AUTH}" -eq 1 ]] && [[ ! -f "${CODEX_AUTH_FILE}" ]]; then
        ( umask 077 && printf '{}\n' > "${CODEX_AUTH_FILE}" )
        echo "Created ${CODEX_AUTH_FILE} — auth tokens will persist after this session." >&2
    fi
    if [[ -f "${CODEX_AUTH_FILE}" ]]; then
        BWRAP_ARGS+=(--bind "${CODEX_AUTH_FILE}" "${CODEX_AUTH_FILE}")
    fi
}

# ── Codex env vars ───────────────────────────────────────────────
# Pass through AIFAPIM_* (Hermes routing) and the documented Codex
# env vars; default OPENAI_API_KEY to "dummy" if unset so the Codex
# provider preflight passes for Hermes-routed setups (the real auth
# is the x-api-key header sourced from AIFAPIM_API_KEY via the
# provider's env_http_headers).
build_codex_env() {
    # AIFAPIM gateway config
    pass_through_if_set AIFAPIM_HOST
    pass_through_if_set AIFAPIM_API_KEY

    # OPENAI_API_KEY is required by Codex's provider preflight.  Hermes
    # ignores the Authorization header (real auth is x-api-key), so a
    # literal "dummy" value is safe and convenient.
    if [[ -z "${OPENAI_API_KEY:-}" ]]; then
        BWRAP_ARGS+=(--setenv OPENAI_API_KEY "dummy")
    else
        pass_through_if_set OPENAI_API_KEY
    fi

    # Documented Codex env vars
    pass_through_if_set CODEX_HOME
    pass_through_if_set CODEX_SQLITE_HOME
    pass_through_if_set CODEX_API_KEY
    pass_through_if_set CODEX_ACCESS_TOKEN
    pass_through_if_set CODEX_CA_CERTIFICATE
    pass_through_if_set SSL_CERT_FILE
    pass_through_if_set RUST_LOG

    # Generic CODEX_* sweep so user-defined overrides flow through.
    local _key
    for _key in $(compgen -e); do
        if [[ "${_key}" == CODEX_* ]]; then
            BWRAP_ARGS+=(--setenv "${_key}" "${!_key}")
        fi
    done

    # --debug wrapper flag: force verbose logging regardless of host env.
    if [[ "${DEBUG_MODE}" -eq 1 ]]; then
        BWRAP_ARGS+=(--setenv RUST_LOG "debug")
    fi
}

# ── Codex install dir (stub) ─────────────────────────────────────
# Codex CLI is installed via npm at /usr/local/lib/node_modules/@openai/codex,
# which build_dynamic_tool_mounts already covers via the npm-prefix mount.
# This stub is kept for symmetry with bwclaude/bwopencode and as a future
# hook for non-npm Codex installs (e.g. the standalone installer's
# /opt/codex layout).
build_codex_bin_mount() {
    :
}

# ═══════════════════════════════════════════════════════════════════
# Main
# ═══════════════════════════════════════════════════════════════════

main() {
    parse_wrapper_args "$@"
    resolve_tool_binary

    if [[ "${SHOW_HELP}" -eq 1 ]]; then
        show_help
        # show_help does exec, never returns
    fi

    detect_bwrap_capabilities
    detect_kernel_capabilities
    resolve_common_paths
    resolve_codex_paths
    detect_shell
    ensure_host_dirs
    check_codex_config
    parse_all_git_includes
    init_sandbox_path

    # Build bwrap argument list
    build_base_sandbox
    build_binary_masks
    build_proc_dev_tmp
    build_etc_mounts
    build_home_tmpfs
    build_workdir_mount
    build_codex_home_mount
    build_git_mounts
    build_pixi_mounts
    build_ccache_mounts
    build_npm_mounts
    build_user_bin_mount
    build_nsls2_mount
    build_codex_bin_mount
    build_dynamic_tool_mounts
    build_extra_path_mounts

    # Environment variables
    build_env_vars
    build_codex_env

    # Launch
    if [[ "${DRY_RUN}" -eq 1 ]]; then
        print_dry_run
    else
        launch_sandbox
    fi
}

main "$@"
