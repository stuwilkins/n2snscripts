#!/usr/bin/env bash
# bwopencode — Launch opencode inside a bubblewrap (bwrap) sandbox.
#
# Requires: bwrap >= 0.4.0 (RHEL 8)
#   - 0.4.0: base functionality
#   - 0.5.0+: --clearenv (fallback: manual --unsetenv for each host var)
#   - 0.6.3+: bind over ro-bind (fallback: skip binary masking)
#
# The sandbox provides filesystem isolation:
#   - Current directory: read-write
#   - OpenCode config: read-only (symlinks resolved)
#   - OpenCode data dir: ephemeral tmpfs with selective persistence
#       - auth.json: persisted only if it already exists on host;
#         otherwise created in tmpfs (discarded on exit)
#       - Database, logs, snapshots, storage, tool-output,
#         project-dotfiles: always persisted
#   - OpenCode cache: read-write
#   - Git config + includes: read-only
#   - Pixi cache: read-write
#   - Pixi config: read-only
#   - ccache config: read-only
#   - ccache cache: read-write
#   - npm config: read-only
#   - npm cache: read-write
#   - System and user binaries: read-only
#   - SSH binaries: masked (ssh, scp, sftp, ssh-agent, etc.)
#   - Network tools: masked (telnet, nc/ncat, socat, rsync, rsh)
#   - Kerberos tools: masked (kinit, klist, kdestroy, kswitch)
#   - Privilege escalation: masked (sudo, su, pkexec)
#   - Namespace tools: masked (nsenter, unshare, chroot)
#   - Keyring tools: masked (keyctl)
#   - SSH/GPG agent env vars: stripped
#   - ~/.bashrc and other shell rc files: not mounted
#
# Usage:
#   bwopencode [bwopencode-options] [opencode arguments...]
#   bwopencode --help
#
# Options:
#   --help, -h      Show this help (wrapper options + opencode's own help).
#   --dry-run       Print the bwrap command that would be executed without running it.
#   --exec CMD      Run CMD inside the sandbox instead of opencode.
#                   Useful for running one-off commands, scripts, or diagnostic tools
#                   inside the fully-configured sandbox environment.
#   --init-auth     Create auth.json on the host so that GitHub OAuth tokens
#                   persist across sessions.  Only needed once per account;
#                   after that auth.json exists and is automatically persisted.
#                   On shared accounts, do NOT use this flag — tokens will be
#                   ephemeral by default (created in tmpfs, discarded on exit).
#   --new-session   Force bwrap --new-session even on kernels with the TIOCSTI cap
#                   guard.  Detaches the controlling tty for stricter isolation at the
#                   cost of SIGWINCH (terminal resize) propagation.

set -euo pipefail

# Source the shared sandbox library.
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
# shellcheck source=../lib/bwrap_sandbox_lib.sh
source "${SCRIPT_DIR}/../lib/bwrap_sandbox_lib.sh"

# ═══════════════════════════════════════════════════════════════════
# Tool-specific state
# ═══════════════════════════════════════════════════════════════════

INIT_AUTH=0
OC_CONFIG_BINDS=()

# ═══════════════════════════════════════════════════════════════════
# Tool-specific functions
# ═══════════════════════════════════════════════════════════════════

parse_wrapper_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help | -h)
                SHOW_HELP=1
                shift
                ;;
            --dry-run)
                DRY_RUN=1
                shift
                ;;
            --exec)
                if [[ $# -lt 2 ]]; then
                    echo "Error: --exec requires a command argument." >&2
                    exit 1
                fi
                TEST_CMD="$2"
                shift 2
                ;;
            --init-auth)
                INIT_AUTH=1
                shift
                ;;
            --new-session)
                # shellcheck disable=SC2034  # consumed by sourced bwrap_sandbox_lib.sh (sandboxed_exec)
                FORCE_NEW_SESSION=1
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    # shellcheck disable=SC2034  # consumed by library's print_dry_run/launch_sandbox
    TOOL_ARGS=("$@")
}

# Find the absolute path to the opencode binary on the host so we do
# not depend on PATH lookup inside the sandbox.
# Sets globals: _TOOL_BIN, _TOOL_CMD
resolve_tool_binary() {
    _TOOL_BIN="$(command -v opencode 2> /dev/null || true)"
    if [[ -z "${_TOOL_BIN}" ]]; then
        echo "Error: 'opencode' not found in PATH." >&2
        exit 1
    fi

    if [[ -n "${TEST_CMD}" ]]; then
        # Split TEST_CMD into array so multi-word commands work correctly.
        read -ra _TOOL_CMD <<< "${TEST_CMD}"
    else
        _TOOL_CMD=("${_TOOL_BIN}")
    fi
}

show_help() {
    cat << 'HELP_EOF'
bwopencode — opencode inside a bubblewrap sandbox

Wrapper options (consumed before opencode sees the command line):
  -h, --help      Show this message followed by opencode's own help.
  --init-auth     Create auth.json on the host so GitHub OAuth tokens persist
                  across sessions.  Run once on a personal account; skip on
                  shared accounts (tokens will be ephemeral by default).
  --dry-run       Print the bwrap command that would be run, then exit.
  --exec CMD      Run CMD inside the fully-configured sandbox instead of opencode.
                  Use this to run scripts, diagnostic tools, or any command with
                  the same filesystem isolation and environment as opencode itself.
                  Example: bwopencode --exec bash
                           bwopencode --exec 'env | sort'
  --new-session   Force bwrap to call setsid(2), detaching the sandbox from the
                  controlling terminal.  This is the default on older kernels
                  (< 5.14); on newer kernels we omit it so that SIGWINCH (terminal
                  resize) propagates from tmux/screen.  Use this flag to opt back
                  into stricter terminal isolation when SIGWINCH is not important.

All other arguments are passed through to opencode unchanged.

HELP_EOF
    # Delegate to opencode --help inside the sandbox so the user sees the full
    # opencode option set in the same invocation.  We re-exec this script with
    # --exec so the sandbox is fully constructed; opencode --help is passed
    # as the sandbox command.
    exec "$0" --exec "${_TOOL_BIN} --help"
}

resolve_opencode_paths() {
    OC_CONFIG_DIR="${XDG_CONFIG_HOME}/opencode"
    OC_DATA_DIR="${XDG_DATA_HOME}/opencode"
    OC_CACHE_DIR="${XDG_CACHE_HOME}/opencode"
    OC_AUTH_FILE="${OC_DATA_DIR}/auth.json"
}

# Ensure writable directories and files exist on host.
ensure_host_dirs() {
    mkdir -p "${OC_DATA_DIR}" "${OC_CACHE_DIR}" \
        "${OC_DATA_DIR}/log" \
        "${OC_DATA_DIR}/plans" \
        "${OC_DATA_DIR}/project-dotfiles" \
        "${OC_DATA_DIR}/snapshot" \
        "${OC_DATA_DIR}/storage" \
        "${OC_DATA_DIR}/tool-output"

    # SQLite database files.  touch is safe: SQLite initialises an empty
    # .db file on first open, and recreates empty -shm/-wal files as part
    # of normal WAL-mode operation.
    touch "${OC_DATA_DIR}/opencode.db" \
          "${OC_DATA_DIR}/opencode.db-shm" \
          "${OC_DATA_DIR}/opencode.db-wal"
}

# Resolve opencode config symlinks.
# We resolve each entry in ~/.config/opencode/ so that symlinks
# pointing outside (e.g. into a dotfiles repo) are followed, and we
# bind the real file at the expected path.  This avoids exposing the
# dotfiles tree inside the sandbox.
resolve_config_symlinks() {
    OC_CONFIG_BINDS=()
    [[ -d "${OC_CONFIG_DIR}" ]] || return 0

    local entry local_resolved
    for entry in "${OC_CONFIG_DIR}"/*; do
        [[ -e "${entry}" ]] || continue
        if [[ -L "${entry}" ]]; then
            local_resolved="$(readlink -f "${entry}")"
        else
            local_resolved="${entry}"
        fi
        OC_CONFIG_BINDS+=("--ro-bind" "${local_resolved}" "${entry}")
    done
}

# ── Managed opencode config (read-only, highest priority) ────────
# If a managed config exists at /etc/opencode/ on the host (deployed
# by ansible), bind-mount it RO into the sandbox.  This is the Linux
# managed-settings path and takes precedence over all other config
# sources; config in the project cannot override it.
#
# Both opencode.json and opencode.jsonc are mounted when present, so
# opencode can pick whichever format it prefers.
#
# On hosts without /etc/opencode/, nothing is bound here — opencode
# falls back to user config at ~/.config/opencode/ as usual.  A
# warning is emitted to stderr in that case so misconfigured managed
# hosts (e.g. ansible deployment failure) are noticed.
build_managed_config() {
    local _has_json=0 _has_jsonc=0
    [[ -f /etc/opencode/opencode.json  ]] && _has_json=1
    [[ -f /etc/opencode/opencode.jsonc ]] && _has_jsonc=1

    if [[ $((_has_json + _has_jsonc)) -gt 0   ]]; then
        # At least one host-managed config exists — bind whichever are present.
        BWRAP_ARGS+=(--dir /etc/opencode)
        if [[ "${_has_json}" -eq 1  ]]; then
            BWRAP_ARGS+=(--ro-bind /etc/opencode/opencode.json /etc/opencode/opencode.json)
        fi
        if [[ "${_has_jsonc}" -eq 1 ]]; then
            BWRAP_ARGS+=(--ro-bind /etc/opencode/opencode.jsonc /etc/opencode/opencode.jsonc)
        fi
    else
        printf 'bwopencode: warning: no /etc/opencode/opencode.json{,c} found on host.\n' >&2
        printf '            Falling back to user config at ~/.config/opencode/.\n' >&2
    fi
}

# ── Persistent .opencode/ directory ──────────────────────────────
# OpenCode creates .opencode/ inside the repo root for project-level
# config, rules, and plugins.  We store this in a persistent location
# outside the repo so it survives `git clean -xfd` on the host.
#
# The persistent directory is keyed by a hash of the bind dir path,
# stored under $XDG_DATA_HOME/opencode/project-dotfiles/<hash>/.
# Inside the sandbox, this is bind-mounted on top of <repo>/.opencode/.
build_persistent_dotdir() {
    [[ -n "${_GIT_ROOT}" ]] || return 0

    local _repo_hash
    _repo_hash="$(printf '%s' "${_GIT_ROOT}" | sha256sum)"
    _repo_hash="${_repo_hash:0:16}"
    local _persist_dir="${OC_DATA_DIR}/project-dotfiles/${_repo_hash}"
    mkdir -p "${_persist_dir}"

    BWRAP_ARGS+=(
        --bind "${_persist_dir}" "${_GIT_ROOT}/.opencode"
    )
}

# ── OpenCode config (read-only, symlinks resolved) ───────────────
build_opencode_config_mount() {
    if [[ ${#OC_CONFIG_BINDS[@]} -gt 0 ]]; then
        BWRAP_ARGS+=(
            --dir "${OC_CONFIG_DIR}"
            "${OC_CONFIG_BINDS[@]}"
        )
    fi
}

# ── OpenCode data (ephemeral tmpfs + selective persistence) ──────
# Mount the data dir as ephemeral tmpfs, then selectively bind-mount
# the files and directories that must persist across sessions.
#
# auth.json is only bind-mounted if it already exists on the host.
# If absent, opencode creates it inside the tmpfs — the token is
# usable for the session but discarded on exit.  This is the desired
# behaviour for shared accounts.  On a personal account, run with
# --init-auth once to create the file and bootstrap persistent auth.
#
# Any files NOT in the persist list (e.g. mcp-auth.json, plans/)
# will be writable inside the sandbox but discarded on exit.
build_opencode_data_mounts() {
    BWRAP_ARGS+=(
        --tmpfs "${OC_DATA_DIR}"
    )

    # Persistent directories
    local _subdir
    for _subdir in log plans project-dotfiles snapshot storage tool-output; do
        BWRAP_ARGS+=(--bind "${OC_DATA_DIR}/${_subdir}" "${OC_DATA_DIR}/${_subdir}")
    done

    # Persistent files
    local _file
    for _file in opencode.db opencode.db-shm opencode.db-wal; do
        BWRAP_ARGS+=(--bind "${OC_DATA_DIR}/${_file}" "${OC_DATA_DIR}/${_file}")
    done

    # auth.json: only persist if it already exists on the host.
    # Use --init-auth on first run to bootstrap persistent auth.
    if [[ "${INIT_AUTH}" -eq 1 ]] && [[ ! -f "${OC_AUTH_FILE}" ]]; then
        # Use umask to ensure file is created with 0600 permissions atomically
        ( umask 077 && printf '{}\n' > "${OC_AUTH_FILE}" )
        echo "Created ${OC_AUTH_FILE} — auth tokens will persist after this session." >&2
    fi
    if [[ -f "${OC_AUTH_FILE}" ]]; then
        BWRAP_ARGS+=(--bind "${OC_AUTH_FILE}" "${OC_AUTH_FILE}")
    fi
}

# ── OpenCode cache (read-write) ──────────────────────────────────
build_opencode_cache_mount() {
    BWRAP_ARGS+=(
        --bind "${OC_CACHE_DIR}" "${OC_CACHE_DIR}"
    )
}

# ── OpenCode env vars ────────────────────────────────────────────
# Pass through any OPENCODE_* env vars (config overrides, etc.)
# Also pass through AIFAPIM_* env vars for NSLS-II Hermes gateway.
build_opencode_env() {
    # AIFAPIM gateway config
    pass_through_if_set AIFAPIM_HOST
    pass_through_if_set AIFAPIM_API_KEY

    local _key
    for _key in $(compgen -e); do
        if [[ "${_key}" == OPENCODE_* ]]; then
            BWRAP_ARGS+=(--setenv "${_key}" "${!_key}")
        fi
    done
}

# ═══════════════════════════════════════════════════════════════════
# Main
# ═══════════════════════════════════════════════════════════════════

main() {
    parse_wrapper_args "$@"
    resolve_tool_binary

    if [[ "${SHOW_HELP}" -eq 1 ]]; then
        show_help
        # show_help does exec, never returns
    fi

    detect_bwrap_capabilities
    detect_kernel_capabilities
    resolve_common_paths
    resolve_opencode_paths
    detect_shell
    ensure_host_dirs
    parse_all_git_includes
    resolve_config_symlinks
    init_sandbox_path

    # Build bwrap argument list
    build_base_sandbox
    build_binary_masks
    build_proc_dev_tmp
    build_etc_mounts
    build_managed_config
    build_home_tmpfs
    build_workdir_mount
    build_persistent_dotdir
    build_opencode_config_mount
    build_opencode_data_mounts
    build_opencode_cache_mount
    build_git_mounts
    build_pixi_mounts
    build_ccache_mounts
    build_npm_mounts
    build_user_bin_mount
    build_nsls2_mount
    build_dynamic_tool_mounts

    # Environment variables
    build_env_vars
    build_opencode_env

    # Launch
    if [[ "${DRY_RUN}" -eq 1 ]]; then
        print_dry_run
    else
        launch_sandbox
    fi
}

main "$@"
