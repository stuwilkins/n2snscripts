root = true

[*.sh]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
switch_case_indent = true
space_redirects = true
binary_next_line = false
keep_padding = true

[bin/*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
switch_case_indent = true
space_redirects = true
binary_next_line = false
keep_padding = true
